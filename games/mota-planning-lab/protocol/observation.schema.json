{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/mota-planning-lab/observation.schema.json",
  "title": "Mota Planning Lab current-floor observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "page",
    "session_id",
    "floor_id",
    "floor_name",
    "floor_number",
    "dimensions",
    "topology",
    "topology_fingerprint",
    "map_instance_id",
    "hero",
    "keys",
    "busy",
    "blocks",
    "captured_at"
  ],
  "properties": {
    "protocol": {"const": 2},
    "page": {"const": "/games/24/"},
    "session_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "floor_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "floor_name": {"type": ["string", "null"], "maxLength": 128},
    "floor_number": {"type": ["integer", "null"]},
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": {"type": "integer", "minimum": 1, "maximum": 256},
        "height": {"type": "integer", "minimum": 1, "maximum": 256}
      }
    },
    "topology": {"$ref": "#/$defs/topology"},
    "topology_fingerprint": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "map_instance_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "hero": {"$ref": "#/$defs/hero"},
    "keys": {"$ref": "#/$defs/keys"},
    "busy": {"type": "boolean"},
    "blocks": {
      "type": "array",
      "maxItems": 8192,
      "items": {"$ref": "#/$defs/block"}
    },
    "shops": {"type": "array", "maxItems": 64, "items": {"$ref": "#/$defs/shop"}},
    "active_menu": {"$ref": "#/$defs/activeMenu"},
    "engine_model": {"$ref": "#/$defs/engineModel"},
    "captured_at": {"type": "integer", "minimum": 0}
  },
  "$defs": {
    "coordinate": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": {"$ref": "#/$defs/coordinate"},
        "y": {"$ref": "#/$defs/coordinate"}
      }
    },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "source", "confidence"],
      "properties": {
        "kind": {"enum": ["rectangle", "valid_cells"]},
        "valid_cells": {"type": "array", "minItems": 1, "maxItems": 65536, "uniqueItems": true, "items": {"$ref": "#/$defs/position"}},
        "source": {"enum": ["engine_current_map", "runtime_observed"]},
        "confidence": {"enum": ["confirmed", "inferred"]}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "rectangle"}}}, "then": {"not": {"required": ["valid_cells"]}}},
        {"if": {"properties": {"kind": {"const": "valid_cells"}}}, "then": {"required": ["valid_cells"]}}
      ]
    },
    "keys": {
      "type": "object",
      "additionalProperties": false,
      "required": ["yellow", "blue", "red"],
      "properties": {
        "yellow": {"type": "integer", "minimum": 0},
        "blue": {"type": "integer", "minimum": 0},
        "red": {"type": "integer", "minimum": 0}
      }
    },
    "hero": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hp", "attack", "defense", "gold", "experience", "loc"],
      "properties": {
        "hp": {"type": "integer", "minimum": 0},
        "attack": {"type": "integer", "minimum": 0},
        "defense": {"type": "integer", "minimum": 0},
        "gold": {"type": "integer", "minimum": 0},
        "experience": {"type": "integer", "minimum": 0},
        "loc": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "direction"],
          "properties": {
            "x": {"$ref": "#/$defs/coordinate"},
            "y": {"$ref": "#/$defs/coordinate"},
            "direction": {"enum": ["up", "down", "left", "right"]}
          }
        }
      }
    },
    "enemy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hp", "attack", "defense", "gold", "experience", "special"],
      "properties": {
        "hp": {"type": "integer", "minimum": 0},
        "attack": {"type": ["integer", "null"], "minimum": 0},
        "defense": {"type": ["integer", "null"], "minimum": 0},
        "gold": {"type": "integer", "minimum": 0},
        "experience": {"type": "integer", "minimum": 0},
        "special": {
          "type": "array",
          "maxItems": 64,
          "items": {"type": ["integer", "string"]}
        }
      }
    },
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "numeric_id", "id", "cls", "trigger", "no_pass", "damage", "enemy"],
      "properties": {
        "x": {"$ref": "#/$defs/coordinate"},
        "y": {"$ref": "#/$defs/coordinate"},
        "numeric_id": {"type": "integer", "minimum": 0},
        "id": {"type": "string", "minLength": 1, "maxLength": 256},
        "cls": {"type": "string", "minLength": 1, "maxLength": 256},
        "trigger": {"type": ["string", "null"], "maxLength": 128},
        "no_pass": {"type": "boolean"},
        "damage": {
          "anyOf": [
            {"type": "integer", "minimum": 0},
            {"const": "???"},
            {"type": "null"}
          ]
        },
        "enemy": {
          "anyOf": [
            {"$ref": "#/$defs/enemy"},
            {"type": "null"}
          ]
        },
        "shop_id": {"type": "string", "minLength": 1, "maxLength": 256}
      }
    },
    "shopEffect": {"type": "object", "additionalProperties": false, "required": ["field", "amount"], "properties": {"field": {"enum": ["hp", "attack", "defense"]}, "amount": {"type": "integer", "minimum": 1}}},
    "shopChoice": {"type": "object", "additionalProperties": false, "required": ["choice_id", "index", "text", "cost", "base_cost", "increment_per_purchase", "effect", "counter_flag", "purchase_count"], "properties": {"choice_id": {"type": "string", "minLength": 1, "maxLength": 256}, "index": {"type": "integer", "minimum": 0, "maximum": 31}, "text": {"type": "string", "minLength": 1, "maxLength": 256}, "cost": {"type": "integer", "minimum": 1}, "base_cost": {"type": "integer", "minimum": 1}, "increment_per_purchase": {"type": "integer", "minimum": 0}, "effect": {"$ref": "#/$defs/shopEffect"}, "counter_flag": {"type": "string", "minLength": 1, "maxLength": 256}, "purchase_count": {"type": "integer", "minimum": 0}}},
    "shop": {"type": "object", "additionalProperties": false, "required": ["supported", "shop_id", "repeatable", "choices"], "properties": {"supported": {"const": true}, "shop_id": {"type": "string", "minLength": 1, "maxLength": 256}, "repeatable": {"const": true}, "choices": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"$ref": "#/$defs/shopChoice"}}}},
    "activeMenu": {"type": "object", "additionalProperties": false, "required": ["shop_id", "menu_id", "ready", "selection", "choices"], "properties": {"shop_id": {"type": "string", "minLength": 1, "maxLength": 256}, "menu_id": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}, "ready": {"const": true}, "selection": {"type": ["integer", "null"], "minimum": 0, "maximum": 31}, "choices": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"type": "string", "minLength": 1, "maxLength": 256}}}},
    "engineModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "catalog_hash", "model_hash", "floors", "blocks", "items", "enemies", "values", "inventory"],
      "properties": {
        "protocol": {"const": 1},
        "catalog_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "model_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "floors": {"type": "array", "maxItems": 1024, "items": {"$ref": "#/$defs/engineFloor"}},
        "blocks": {"type": "array", "maxItems": 16384, "items": {"$ref": "#/$defs/engineBlockDefinition"}},
        "items": {"type": "array", "maxItems": 8192, "items": {"$ref": "#/$defs/engineItem"}},
        "enemies": {"type": "array", "maxItems": 8192, "items": {"$ref": "#/$defs/engineEnemy"}},
        "values": {"type": "object", "maxProperties": 4096, "additionalProperties": {"type": "number"}},
        "inventory": {"$ref": "#/$defs/engineInventory"},
        "solver_model": {"$ref": "#/$defs/solverModel"}
      }
    },
    "solverGoal": {"type": "object", "additionalProperties": false, "required": ["kind", "floor_id", "x", "y"], "properties": {"kind": {"const": "location"}, "floor_id": {"type": "string", "minLength": 1, "maxLength": 256}, "x": {"$ref": "#/$defs/coordinate"}, "y": {"$ref": "#/$defs/coordinate"}}},
    "solverGoalSet": {"type": "object", "additionalProperties": false, "required": ["kind", "locations"], "properties": {"kind": {"const": "any_location"}, "locations": {"type": "array", "minItems": 2, "maxItems": 32, "items": {"$ref": "#/$defs/solverGoal"}}}},
    "solverDelta": {"type": "object", "additionalProperties": false, "required": ["hp", "attack", "defense", "gold", "experience", "keys", "inventory"], "properties": {"hp": {"type": "integer", "minimum": 0}, "attack": {"type": "integer", "minimum": 0}, "defense": {"type": "integer", "minimum": 0}, "gold": {"type": "integer", "minimum": 0}, "experience": {"type": "integer", "minimum": 0}, "keys": {"$ref": "#/$defs/keys"}, "inventory": {"type": "object", "maxProperties": 4096, "propertyNames": {"type": "string", "minLength": 1, "maxLength": 256}, "additionalProperties": {"type": "integer", "minimum": 0}}}},
    "solverBlockBase": {"type": "object", "required": ["floor_id", "x", "y", "block_id", "numeric_id", "kind"], "properties": {"floor_id": {"type": "string", "minLength": 1, "maxLength": 256}, "x": {"$ref": "#/$defs/coordinate"}, "y": {"$ref": "#/$defs/coordinate"}, "block_id": {"type": "string", "minLength": 1, "maxLength": 256}, "numeric_id": {"type": "integer", "minimum": 0}, "kind": {"enum": ["terrain", "opaque", "door", "enemy", "resource", "transition", "shop"]}}},
    "solverBlock": {"oneOf": [
      {"allOf": [{"$ref": "#/$defs/solverBlockBase"}, {"properties": {"kind": {"const": "terrain"}}}], "unevaluatedProperties": false},
      {"allOf": [{"$ref": "#/$defs/solverBlockBase"}, {"required": ["reason"], "properties": {"kind": {"const": "opaque"}, "reason": {"type": "string", "minLength": 1, "maxLength": 256}}}], "unevaluatedProperties": false},
      {"allOf": [{"$ref": "#/$defs/solverBlockBase"}, {"required": ["key_cost"], "properties": {"kind": {"const": "door"}, "key_cost": {"$ref": "#/$defs/keys"}}}], "unevaluatedProperties": false},
      {"allOf": [{"$ref": "#/$defs/solverBlockBase"}, {"required": ["enemy"], "properties": {"kind": {"const": "enemy"}, "enemy": {"$ref": "#/$defs/engineEnemy"}}}], "unevaluatedProperties": false},
      {"allOf": [{"$ref": "#/$defs/solverBlockBase"}, {"required": ["delta"], "properties": {"kind": {"const": "resource"}, "delta": {"$ref": "#/$defs/solverDelta"}}}], "unevaluatedProperties": false},
      {"allOf": [
        {"$ref": "#/$defs/solverBlockBase"},
        {"required": ["target"], "properties": {
          "kind": {"const": "transition"},
          "target": {"type": "object", "additionalProperties": false, "required": ["floor_id", "x", "y"], "properties": {
            "floor_id": {"type": "string", "minLength": 1, "maxLength": 256},
            "x": {"$ref": "#/$defs/coordinate"},
            "y": {"$ref": "#/$defs/coordinate"}
          }}
        }}
      ], "unevaluatedProperties": false},
      {"allOf": [{"$ref": "#/$defs/solverBlockBase"}, {"required": ["shop_id"], "properties": {"kind": {"const": "shop"}, "shop_id": {"type": "string", "minLength": 1, "maxLength": 256}}}], "unevaluatedProperties": false}
    ]},
    "solverFloor": {"type": "object", "additionalProperties": false, "required": ["floor_id", "width", "height", "topology", "blocks"], "properties": {"floor_id": {"type": "string", "minLength": 1, "maxLength": 256}, "width": {"type": "integer", "minimum": 1, "maximum": 256}, "height": {"type": "integer", "minimum": 1, "maximum": 256}, "topology": {"$ref": "#/$defs/engineTopology"}, "blocks": {"type": "array", "maxItems": 16384, "items": {"$ref": "#/$defs/solverBlock"}}}},
    "solverBlocker": {"type": "object", "additionalProperties": false, "required": ["code", "detail"], "properties": {"code": {"type": "string", "minLength": 1, "maxLength": 96}, "detail": {"type": "string", "minLength": 1, "maxLength": 512}}},
    "solverModel": {"type": "object", "additionalProperties": false, "required": ["protocol", "terminal", "floors", "shops", "blockers"], "properties": {"protocol": {"const": 1}, "terminal": {"anyOf": [{"$ref": "#/$defs/solverGoal"}, {"$ref": "#/$defs/solverGoalSet"}, {"type": "null"}]}, "floors": {"type": "array", "minItems": 1, "maxItems": 1024, "items": {"$ref": "#/$defs/solverFloor"}}, "shops": {"type": "array", "maxItems": 1024, "items": {"$ref": "#/$defs/shop"}}, "blockers": {"type": "array", "maxItems": 65536, "items": {"$ref": "#/$defs/solverBlocker"}}, "search_budget": {"type": "integer", "minimum": 1, "maximum": 50000}}},
    "engineTopology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"enum": ["rectangle", "valid_cells"]},
        "valid_cells": {"type": "array", "minItems": 1, "maxItems": 65536, "items": {"$ref": "#/$defs/position"}}
      }
    },
    "engineMapBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "numeric_id", "id", "cls", "trigger", "no_pass", "disabled"],
      "properties": {
        "x": {"$ref": "#/$defs/coordinate"}, "y": {"$ref": "#/$defs/coordinate"},
        "numeric_id": {"type": "integer", "minimum": 0},
        "id": {"type": "string", "minLength": 1, "maxLength": 256},
        "cls": {"type": "string", "minLength": 1, "maxLength": 256},
        "trigger": {"type": ["string", "null"], "maxLength": 128},
        "no_pass": {"type": "boolean"}, "disabled": {"type": "boolean"},
        "shop_id": {"type": "string", "minLength": 1, "maxLength": 256}
      }
    },
    "engineChangeFloor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": {"$ref": "#/$defs/coordinate"}, "y": {"$ref": "#/$defs/coordinate"},
        "floor_id": {"type": ["string", "null"], "minLength": 1, "maxLength": 256},
        "loc": {"anyOf": [{"$ref": "#/$defs/position"}, {"type": "null"}]},
        "direction": {"type": ["string", "null"], "enum": ["up", "down", "left", "right", null]},
        "stair": {"type": ["string", "null"], "maxLength": 128},
        "time": {"type": ["integer", "null"], "minimum": 0},
        "ignore_change_floor": {"type": ["boolean", "null"]},
        "opaque": {"type": "boolean"}
      }
    },
    "engineFloor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["floor_id", "width", "height", "topology", "map", "blocks", "change_floor", "ratio"],
      "properties": {
        "floor_id": {"type": "string", "minLength": 1, "maxLength": 256},
        "title": {"type": ["string", "null"], "maxLength": 256},
        "width": {"type": "integer", "minimum": 1, "maximum": 256},
        "height": {"type": "integer", "minimum": 1, "maximum": 256},
        "topology": {"$ref": "#/$defs/engineTopology"},
        "map": {"type": "array", "maxItems": 256, "items": {"type": "array", "maxItems": 256, "items": {"type": ["integer", "null"], "minimum": 0}}},
        "blocks": {"type": "array", "maxItems": 8192, "items": {"$ref": "#/$defs/engineMapBlock"}},
        "change_floor": {"type": "array", "maxItems": 8192, "items": {"$ref": "#/$defs/engineChangeFloor"}},
        "ratio": {"type": "number"},
        "terminal_goals": {"type": "array", "maxItems": 32, "items": {"type": "object"}},
        "opaque_events": {"type": "array", "maxItems": 8192, "items": {"type": "object"}}
      }
    },
    "engineBlockDefinition": {
      "type": "object", "additionalProperties": false,
      "required": ["numeric_id", "id", "cls", "trigger", "no_pass", "door_info"],
      "properties": {
        "numeric_id": {"type": "integer", "minimum": 0},
        "id": {"type": "string", "minLength": 1, "maxLength": 256},
        "cls": {"type": "string", "minLength": 1, "maxLength": 256},
        "trigger": {"type": ["string", "null"], "maxLength": 128},
        "no_pass": {"type": "boolean"},
        "door_info": {"anyOf": [{"type": "object", "additionalProperties": false, "required": ["keys"], "properties": {"keys": {"type": "object", "maxProperties": 32, "additionalProperties": {"type": "integer", "minimum": 1}}}}, {"type": "null"}]}
      }
    },
    "engineItem": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "cls", "name", "text", "item_effect", "item_effect_tip", "use_item_event", "complex"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 256},
        "cls": {"type": "string", "minLength": 1, "maxLength": 256},
        "name": {"type": ["string", "null"], "maxLength": 256},
        "text": {"type": ["string", "null"], "maxLength": 4096},
        "item_effect": {"type": ["string", "null"], "maxLength": 16384},
        "item_effect_tip": {"type": ["string", "null"], "maxLength": 4096},
        "use_item_event": {"type": ["boolean", "string", "array", "object", "null"]},
        "complex": {"type": "boolean"}
      }
    },
    "engineEnemy": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "hp", "attack", "defense", "gold", "experience", "special"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 256},
        "hp": {"type": "integer", "minimum": 0},
        "attack": {"type": ["integer", "null"], "minimum": 0},
        "defense": {"type": ["integer", "null"], "minimum": 0},
        "gold": {"type": "integer", "minimum": 0},
        "experience": {"type": "integer", "minimum": 0},
        "special": {"type": "array", "maxItems": 64, "items": {"type": ["integer", "string"]}}
      }
    },
    "engineInventory": {
      "type": "object", "additionalProperties": false, "required": ["classes", "key_slots"],
      "properties": {
        "classes": {"type": "object", "maxProperties": 64, "additionalProperties": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}}},
        "key_slots": {"type": "object", "additionalProperties": false, "properties": {"yellow": {"type": ["string", "null"]}, "blue": {"type": ["string", "null"]}, "red": {"type": ["string", "null"]}}}
      }
    }
  }
}
