{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/mota-planning-lab/cycle-response.schema.json",
  "title": "Mota Planning Lab cycle response",
  "oneOf": [
    {"$ref": "#/$defs/execute"},
    {"$ref": "#/$defs/pause"},
    {"$ref": "#/$defs/idle"},
    {"$ref": "#/$defs/error"}
  ],
  "$defs": {
    "pauseKind": {
      "enum": [
        "NEW_OBJECT_OR_MECHANISM",
        "UNKNOWN_DAMAGE",
        "UNKNOWN_FLOOR",
        "EXPECTED_DELTA_MISMATCH",
        "GUARD_MISMATCH",
        "UNSUPPORTED_INTERACTION",
        "DECISION_SERVICE_UNAVAILABLE",
        "ENGINE_API_INCOMPATIBLE",
        "SESSION_CONFIRMATION_REQUIRED",
        "PLANNING_BUDGET_EXHAUSTED"
      ]
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": {"type": "integer", "minimum": 0, "maximum": 255},
        "y": {"type": "integer", "minimum": 0, "maximum": 255}
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "direction"],
      "properties": {
        "x": {"type": "integer", "minimum": 0, "maximum": 255},
        "y": {"type": "integer", "minimum": 0, "maximum": 255},
        "direction": {"enum": ["up", "down", "left", "right"]}
      }
    },
    "keys": {
      "type": "object",
      "additionalProperties": false,
      "required": ["yellow", "blue", "red"],
      "properties": {
        "yellow": {"type": "integer", "minimum": 0},
        "blue": {"type": "integer", "minimum": 0},
        "red": {"type": "integer", "minimum": 0}
      }
    },
    "guard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "map_instance_id", "dimensions", "topology_fingerprint", "floor_id", "floor", "position", "hp", "attack", "defense", "gold", "experience", "keys"],
      "properties": {
        "session_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "map_instance_id": {"type": "string", "minLength": 1, "maxLength": 256},
        "dimensions": {
          "type": "object", "additionalProperties": false, "required": ["width", "height"],
          "properties": {"width": {"type": "integer", "minimum": 1, "maximum": 256}, "height": {"type": "integer", "minimum": 1, "maximum": 256}}
        },
        "topology_fingerprint": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "floor_id": {"type": "string", "minLength": 1, "maxLength": 256},
        "floor": {"type": ["integer", "null"]},
        "position": {"$ref": "#/$defs/location"},
        "hp": {"type": "integer", "minimum": 0},
        "attack": {"type": "integer", "minimum": 0},
        "defense": {"type": "integer", "minimum": 0},
        "gold": {"type": "integer", "minimum": 0},
        "experience": {"type": "integer", "minimum": 0},
        "keys": {"$ref": "#/$defs/keys"}
      }
    },
    "operation": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["type", "x", "y"],
          "properties": {"type": {"const": "grid"}, "x": {"type": "integer", "minimum": 0, "maximum": 255}, "y": {"type": "integer", "minimum": 0, "maximum": 255}}},
        {"type": "object", "additionalProperties": false,
          "required": ["type", "shop_id", "menu_id", "choice_id", "choice_index", "expected_cost", "expected_effect", "expected_purchase_count"],
          "properties": {"type": {"const": "menu_choice"}, "shop_id": {"type": "string", "minLength": 1, "maxLength": 256}, "menu_id": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}, "choice_id": {"type": "string", "minLength": 1, "maxLength": 256}, "choice_index": {"type": "integer", "minimum": 0, "maximum": 8}, "expected_cost": {"type": "integer", "minimum": 1}, "expected_effect": {"type": "object", "additionalProperties": false, "required": ["field", "amount"], "properties": {"field": {"enum": ["hp", "attack", "defense"]}, "amount": {"type": "integer", "minimum": 1}}}, "expected_purchase_count": {"type": "integer", "minimum": 0}}}
      ]
    },
    "blockRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "id"],
      "properties": {
        "x": {"type": "integer", "minimum": 0, "maximum": 255},
        "y": {"type": "integer", "minimum": 0, "maximum": 255},
        "id": {"type": "string", "minLength": 1, "maxLength": 256},
        "cls": {"type": "string", "minLength": 1, "maxLength": 256},
        "trigger": {"type": ["string", "null"], "maxLength": 128},
        "numeric_id": {"type": "integer", "minimum": 0}
      }
    },
    "expectedDelta": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "allOf": [
        {
          "if": {"required": ["map_instance_id"]},
          "then": {
            "not": {
              "anyOf": [
                {"required": ["removed_blocks"]},
                {"required": ["added_blocks"]}
              ]
            }
          }
        }
      ],
      "properties": {
        "hp": {"type": "integer"},
        "attack": {"type": "integer"},
        "defense": {"type": "integer"},
        "gold": {"type": "integer"},
        "experience": {"type": "integer"},
        "keys": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "yellow": {"type": "integer"},
            "blue": {"type": "integer"},
            "red": {"type": "integer"}
          }
        },
        "inventory": {
          "type": "object",
          "maxProperties": 4096,
          "propertyNames": {"type": "string", "minLength": 1, "maxLength": 256},
          "additionalProperties": {"type": "integer"}
        },
        "position": {"$ref": "#/$defs/position"},
        "floor_id": {
          "anyOf": [
            {"type": "string", "minLength": 1, "maxLength": 256},
            {"type": "null"}
          ]
        },
        "map_instance_id": {
          "anyOf": [
            {"type": "string", "minLength": 1, "maxLength": 256},
            {"type": "null"}
          ]
        },
        "removed_blocks": {"type": "array", "maxItems": 8192, "items": {"$ref": "#/$defs/blockRef"}},
        "added_blocks": {"type": "array", "maxItems": 8192, "items": {"$ref": "#/$defs/blockRef"}}
      }
    },
    "registryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "cls", "trigger", "category", "passable", "boundary", "fast_path", "version"],
      "properties": {
        "id": {"type": "string", "minLength": 1, "maxLength": 256},
        "cls": {"type": "string", "minLength": 1, "maxLength": 256},
        "trigger": {"type": ["string", "null"], "maxLength": 128},
        "category": {"enum": ["terrain", "wall", "door", "resource", "enemy", "npc", "mechanism", "stair", "other"]},
        "passable": {"type": "boolean"},
        "boundary": {"type": "boolean"},
        "fast_path": {"type": "boolean"},
        "version": {"type": "integer", "minimum": 1}
      }
    },
    "registryEntries": {
      "type": "array",
      "maxItems": 8192,
      "items": {"$ref": "#/$defs/registryEntry"}
    },
    "scanState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase", "anchor_map_instance_id", "current_map_instance_id",
        "scanned_map_instance_ids", "pending_transition_count",
        "traversed_transition_count", "frontier_count", "reason"
      ],
      "properties": {
        "phase": {"enum": ["anchor", "discover", "sweep", "complete", "paused"]},
        "anchor_map_instance_id": {"type": "string", "minLength": 1, "maxLength": 256},
        "current_map_instance_id": {"type": "string", "minLength": 1, "maxLength": 256},
        "scanned_map_instance_ids": {
          "type": "array", "maxItems": 65536, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 256}
        },
        "pending_transition_count": {"type": "integer", "minimum": 0},
        "traversed_transition_count": {"type": "integer", "minimum": 0},
        "frontier_count": {"type": "integer", "minimum": 0},
        "reason": {"type": "string", "minLength": 1, "maxLength": 512}
      }
    },
    "globalShadowStep": {"oneOf": [
      {"type": "object", "additionalProperties": false, "required": ["step_kind", "floor_id", "x", "y", "block_id", "details"], "properties": {"step_kind": {"const": "door"}, "floor_id": {"type": "string", "minLength": 1, "maxLength": 256}, "x": {"type": "integer", "minimum": 0, "maximum": 255}, "y": {"type": "integer", "minimum": 0, "maximum": 255}, "block_id": {"type": "string", "minLength": 1, "maxLength": 256}, "details": {"type": "object", "additionalProperties": false, "required": ["key_cost"], "properties": {"key_cost": {"$ref": "#/$defs/keys"}}}}},
      {"type": "object", "additionalProperties": false, "required": ["step_kind", "floor_id", "x", "y", "block_id", "details"], "properties": {"step_kind": {"const": "enemy"}, "floor_id": {"type": "string", "minLength": 1, "maxLength": 256}, "x": {"type": "integer", "minimum": 0, "maximum": 255}, "y": {"type": "integer", "minimum": 0, "maximum": 255}, "block_id": {"type": "string", "minLength": 1, "maxLength": 256}, "details": {"type": "object", "additionalProperties": false, "required": ["hp_loss"], "properties": {"hp_loss": {"type": "number", "minimum": 0}}}}},
      {"type": "object", "additionalProperties": false, "required": ["step_kind", "floor_id", "x", "y", "block_id", "details"], "properties": {"step_kind": {"const": "resource"}, "floor_id": {"type": "string", "minLength": 1, "maxLength": 256}, "x": {"type": "integer", "minimum": 0, "maximum": 255}, "y": {"type": "integer", "minimum": 0, "maximum": 255}, "block_id": {"type": "string", "minLength": 1, "maxLength": 256}, "details": {"$ref": "#/$defs/globalResourceDelta"}}},
      {"type": "object", "additionalProperties": false, "required": ["step_kind", "floor_id", "x", "y", "block_id", "details"], "properties": {"step_kind": {"const": "transition"}, "floor_id": {"type": "string", "minLength": 1, "maxLength": 256}, "x": {"type": "integer", "minimum": 0, "maximum": 255}, "y": {"type": "integer", "minimum": 0, "maximum": 255}, "block_id": {"type": "string", "minLength": 1, "maxLength": 256}, "details": {"type": "object", "additionalProperties": false, "maxProperties": 0}}},
      {"type": "object", "additionalProperties": false, "required": ["step_kind", "floor_id", "shop_id", "choice_id", "details"], "properties": {"step_kind": {"const": "shop"}, "floor_id": {"type": "string", "minLength": 1, "maxLength": 256}, "shop_id": {"type": "string", "minLength": 1, "maxLength": 256}, "choice_id": {"type": "string", "minLength": 1, "maxLength": 256}, "details": {"type": "object", "additionalProperties": false, "required": ["currency", "cost", "purchase_count_before", "effects"], "properties": {"currency": {"enum": ["gold", "experience", "yellow", "blue", "red"]}, "cost": {"type": "integer", "minimum": 1}, "purchase_count_before": {"type": "integer", "minimum": 0}, "effects": {"type": "array", "minItems": 1, "maxItems": 8, "items": {"type": "object", "additionalProperties": false, "required": ["field", "amount"], "properties": {"field": {"enum": ["level", "hp", "attack", "defense", "gold", "experience", "yellow", "blue", "red"]}, "amount": {"type": "integer", "minimum": 1}}}}}}}},
      {"type": "object", "additionalProperties": false, "required": ["step_kind", "floor_id", "x", "y", "block_id", "details"], "properties": {"step_kind": {"const": "event"}, "floor_id": {"type": "string", "minLength": 1, "maxLength": 256}, "x": {"type": "integer", "minimum": 0, "maximum": 255}, "y": {"type": "integer", "minimum": 0, "maximum": 255}, "block_id": {"type": "string", "minLength": 1, "maxLength": 256}, "details": {"type": "object", "additionalProperties": false, "required": ["event_id"], "properties": {"event_id": {"type": "string", "minLength": 1, "maxLength": 128}}}}},
      {"type": "object", "additionalProperties": false, "required": ["step_kind", "floor_id", "x", "y", "details"], "properties": {"step_kind": {"const": "terminal"}, "floor_id": {"type": "string", "minLength": 1, "maxLength": 256}, "x": {"type": "integer", "minimum": 0, "maximum": 255}, "y": {"type": "integer", "minimum": 0, "maximum": 255}, "details": {"type": "object", "additionalProperties": false, "maxProperties": 0}}}
    ]},
    "globalResourceDelta": {
      "type": "object", "additionalProperties": false,
      "required": ["hp", "attack", "defense", "gold", "experience", "level", "keys", "inventory"],
      "properties": {
        "hp": {"type": "integer", "minimum": 0}, "attack": {"type": "integer", "minimum": 0},
        "defense": {"type": "integer", "minimum": 0}, "gold": {"type": "integer", "minimum": 0},
        "experience": {"type": "integer", "minimum": 0}, "level": {"type": "integer", "minimum": 0},
        "multiply": {"type": "object", "additionalProperties": false, "properties": {
          "hp": {"type": "number", "exclusiveMinimum": 0},
          "attack": {"type": "number", "exclusiveMinimum": 0},
          "defense": {"type": "number", "exclusiveMinimum": 0}
        }},
        "keys": {"$ref": "#/$defs/keys"},
        "inventory": {"type": "object", "maxProperties": 4096,
          "propertyNames": {"type": "string", "minLength": 1, "maxLength": 256,
            "not": {"enum": ["action", "action_id", "execute", "operation", "operations", "guard"]}},
          "additionalProperties": {"type": "integer", "minimum": 0}}
      }
    },
    "shadow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "reason", "cycle"],
      "properties": {
        "mode": {"const": "read_only"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 512},
        "cycle": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
        "analysis": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scope", "reachable_cell_count", "candidate_limit", "total_candidate_count", "truncated", "candidates"],
          "properties": {
            "scope": {"const": "current_floor_immediate"},
            "reachable_cell_count": {"type": "integer", "minimum": 1, "maximum": 65536},
            "candidate_limit": {"type": "integer", "minimum": 1, "maximum": 256},
            "total_candidate_count": {"type": "integer", "minimum": 0, "maximum": 65536},
            "truncated": {"type": "boolean"},
            "candidates": {
              "type": "array",
              "maxItems": 256,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["candidate_id", "kind", "block_id", "numeric_id", "x", "y", "distance", "feasibility", "hp_loss", "key_cost"],
                "properties": {
                  "candidate_id": {"type": "string", "minLength": 1, "maxLength": 768},
                  "kind": {"enum": ["enemy", "door", "resource", "stair"]},
                  "block_id": {"type": "string", "minLength": 1, "maxLength": 256},
                  "numeric_id": {"type": "integer", "minimum": 0},
                  "x": {"type": "integer", "minimum": 0, "maximum": 255},
                  "y": {"type": "integer", "minimum": 0, "maximum": 255},
                  "distance": {"type": "integer", "minimum": 1},
                  "feasibility": {"enum": ["known_feasible", "known_lethal", "missing_key", "unknown_cost"]},
                  "hp_loss": {"type": ["integer", "null"], "minimum": 0},
                  "key_cost": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["yellow", "blue", "red"],
                    "properties": {
                      "yellow": {"type": "integer", "minimum": 0, "maximum": 1},
                      "blue": {"type": "integer", "minimum": 0, "maximum": 1},
                      "red": {"type": "integer", "minimum": 0, "maximum": 1}
                    }
                  }
                }
              }
            },
            "global": {
              "type": "object",
              "additionalProperties": false,
              "required": ["scope", "proof", "reason", "truncated", "explored_states", "blockers", "route", "first_suggestion"],
              "allOf": [
                {"if": {"properties": {"proof": {"const": "proven"}}, "required": ["proof"]}, "then": {"required": ["terminal_hp", "terminal_attack", "terminal_defense"], "properties": {"truncated": {"const": false}, "route": {"type": "object"}, "first_suggestion": {"$ref": "#/$defs/globalShadowStep"}}}, "else": {"not": {"anyOf": [{"required": ["terminal_hp"]}, {"required": ["terminal_attack"]}, {"required": ["terminal_defense"]}]}, "properties": {"route": {"type": "null"}}}},
                {"if": {"properties": {"decision_mode": {"const": "certified_immediate_action"}}, "required": ["decision_mode"]}, "then": {"properties": {"proof": {"const": "unproven"}, "reason": {"const": "deferred_for_certified_immediate_combat_gem"}, "truncated": {"const": false}, "explored_states": {"const": 0}, "blockers": {"type": "array", "maxItems": 0}, "route": {"type": "null"}, "first_suggestion": {"allOf": [{"$ref": "#/$defs/globalShadowStep"}, {"type": "object", "required": ["step_kind", "block_id"], "properties": {"step_kind": {"const": "resource"}, "block_id": {"enum": ["redGem", "blueGem"]}}}]}}}, "else": {"if": {"properties": {"proof": {"const": "proven"}}, "required": ["proof"]}, "then": {}, "else": {"properties": {"first_suggestion": {"type": "null"}}}}},
                {"if": {"properties": {"truncated": {"const": true}}, "required": ["truncated"]}, "then": {"properties": {"proof": {"const": "unproven"}, "reason": {"const": "search_budget_exhausted"}}}},
                {"if": {"properties": {"reason": {"const": "search_budget_exhausted"}}, "required": ["reason"]}, "then": {"properties": {"proof": {"const": "unproven"}, "truncated": {"const": true}}}}
              ],
              "properties": {
                "scope": {"const": "global_terminal_route"},
                "proof": {"enum": ["proven", "unproven", "unsupported"]},
                "decision_mode": {"const": "certified_immediate_action"},
                "reason": {"type": "string", "minLength": 1, "maxLength": 512},
                "truncated": {"type": "boolean"},
                "explored_states": {"type": "integer", "minimum": 0, "maximum": 50000},
                "terminal_hp": {"type": "number", "exclusiveMinimum": 0},
                "terminal_attack": {"type": "number", "minimum": 0},
                "terminal_defense": {"type": "number", "minimum": 0},
                "blockers": {"type": "array", "maxItems": 65536, "items": {"type": "object", "additionalProperties": false, "required": ["code", "detail"], "properties": {"code": {"type": "string", "minLength": 1, "maxLength": 256}, "detail": {"type": "string", "minLength": 1, "maxLength": 512}}}},
                "route": {"anyOf": [{"type": "object", "additionalProperties": false, "required": ["step_count", "steps"], "properties": {"step_count": {"type": "integer", "minimum": 1}, "steps": {"type": "array", "minItems": 1, "maxItems": 65536, "items": {"$ref": "#/$defs/globalShadowStep"}}}}, {"type": "null"}]},
                "first_suggestion": {"anyOf": [{"$ref": "#/$defs/globalShadowStep"}, {"type": "null"}]}
              }
            }
          }
        },
        "observation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["session_id", "floor_id", "map_instance_id"],
          "properties": {
            "session_id": {"type": "string", "minLength": 1, "maxLength": 256},
            "floor_id": {"type": "string", "minLength": 1, "maxLength": 256},
            "map_instance_id": {"type": "string", "minLength": 1, "maxLength": 256}
          }
        }
      }
    },
    "execute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "action_id", "action_kind", "reason", "operations", "guard", "expected_delta"],
      "properties": {
        "status": {"const": "execute"},
        "action_id": {"type": "string", "pattern": "^AUTO-[A-F0-9]{16}$"},
        "action_kind": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,63}$"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 512},
        "operations": {"type": "array", "minItems": 1, "maxItems": 3, "items": {"$ref": "#/$defs/operation"}},
        "guard": {"$ref": "#/$defs/guard"},
        "expected_delta": {"$ref": "#/$defs/expectedDelta"},
        "supersedes_action_id": {
          "anyOf": [
            {"type": "string", "pattern": "^AUTO-[A-F0-9]{16}$"},
            {"type": "null"}
          ]
        },
        "registry_entries": {"$ref": "#/$defs/registryEntries"},
        "scan_state": {"$ref": "#/$defs/scanState"},
        "acknowledged_action_id": {"type": "string", "pattern": "^AUTO-[A-F0-9]{16}$"}
      }
    },
    "pause": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "pause_kind", "detail_code", "reason", "details"],
      "properties": {
        "status": {"const": "pause"},
        "pause_kind": {"$ref": "#/$defs/pauseKind"},
        "detail_code": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,95}$"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 512},
        "details": {"type": "object"},
        "evidence_path": {"type": "string"},
        "registry_entries": {"$ref": "#/$defs/registryEntries"},
        "scan_state": {"$ref": "#/$defs/scanState"},
        "acknowledged_action_id": {"type": "string", "pattern": "^AUTO-[A-F0-9]{16}$"}
      }
    },
    "idle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason"],
      "properties": {
        "status": {"const": "idle"},
        "reason": {"type": "string", "minLength": 1, "maxLength": 512},
        "registry_entries": {"$ref": "#/$defs/registryEntries"},
        "scan_state": {"$ref": "#/$defs/scanState"},
        "shadow": {"$ref": "#/$defs/shadow"},
        "acknowledged_action_id": {"type": "string", "pattern": "^AUTO-[A-F0-9]{16}$"}
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "error_code", "reason"],
      "properties": {
        "status": {"const": "error"},
        "error_code": {"type": "string", "minLength": 1, "maxLength": 128},
        "reason": {"type": "string", "maxLength": 1000},
        "errors": {"type": "array", "items": {"type": "object"}},
        "acknowledged_action_id": {"type": "string", "pattern": "^AUTO-[A-F0-9]{16}$"}
      }
    }
  }
}
